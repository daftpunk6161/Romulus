<UserControl x:Class="Romulus.UI.Wpf.Views.ReviewInboxView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- T-W4-REVIEW-INBOX (W5): drei Lanes Safe/Review/Blocked.
       Datenquelle: MainViewModel.ReviewInbox (ReviewInboxViewModel)
       projiziert ueber ReviewInboxProjection (SoT). Diese View
       berechnet NICHTS selbst; sie ist reine Projektion. -->
  <DockPanel LastChildFill="True" DataContext="{Binding ReviewInbox}">
    <Border DockPanel.Dock="Top" Style="{StaticResource SectionCard}" Margin="20,16,20,8">
      <StackPanel>
        <TextBlock Text="Review-Inbox" Style="{StaticResource SectionHeader}"/>
        <TextBlock
          Text="Drei Lanes: Safe (sortbereit), Review (Pruefung noetig), Blocked (gesperrt). Bulk-Quarantine erfordert getippten CONFIRM-Token. Decision-Explainer per Zeile."
          Style="{StaticResource CaptionText}" Margin="0,4,0,12" TextWrapping="Wrap"/>
      </StackPanel>
    </Border>

    <Grid Margin="20,8,20,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Safe lane -->
      <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,8,0">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Style="{StaticResource SubsectionHeader}"
                     Margin="0,0,0,8">
            <Run Text="Safe ("/>
            <Run Text="{Binding Safe.Count, Mode=OneWay}"/>
            <Run Text=")"/>
          </TextBlock>
          <DataGrid ItemsSource="{Binding Safe}" AutoGenerateColumns="False" IsReadOnly="True"
                    HeadersVisibility="Column" GridLinesVisibility="None"
                    CanUserAddRows="False" CanUserDeleteRows="False">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Datei" Binding="{Binding FileName}" Width="*"/>
              <DataGridTextColumn Header="Konsole" Binding="{Binding ConsoleKey}" Width="Auto"/>
              <DataGridTextColumn Header="Decision" Binding="{Binding SortDecision}" Width="Auto"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>

      <!-- Review lane (with bulk + Explainer) -->
      <Border Grid.Column="1" Style="{StaticResource SectionCard}" Margin="8,0,8,0">
        <DockPanel>
          <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <TextBlock Style="{StaticResource SubsectionHeader}">
              <Run Text="Review ("/>
              <Run Text="{Binding Review.Count, Mode=OneWay}"/>
              <Run Text=")"/>
            </TextBlock>
            <Button DockPanel.Dock="Right" Content="Quarantine (CONFIRM)"
                    Command="{Binding QuarantineSelectedReviewCommand}"
                    Style="{StaticResource DangerButton}" Margin="8,0,0,0"/>
          </DockPanel>
          <DataGrid ItemsSource="{Binding Review}" AutoGenerateColumns="False"
                    HeadersVisibility="Column" GridLinesVisibility="None"
                    CanUserAddRows="False" CanUserDeleteRows="False">
            <DataGrid.Columns>
              <DataGridCheckBoxColumn Header="" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="Auto"/>
              <DataGridTextColumn Header="Datei" Binding="{Binding FileName}" Width="*" IsReadOnly="True"/>
              <DataGridTextColumn Header="Konsole" Binding="{Binding ConsoleKey}" Width="Auto" IsReadOnly="True"/>
              <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="*" IsReadOnly="True"/>
              <DataGridTemplateColumn Header="Explain" Width="Auto">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <Button Content="?"
                            Command="{Binding DataContext.OpenExplainerCommand,
                                       RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"/>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>

      <!-- Blocked lane -->
      <Border Grid.Column="2" Style="{StaticResource SectionCard}" Margin="8,0,0,0">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Style="{StaticResource SubsectionHeader}"
                     Margin="0,0,0,8">
            <Run Text="Blocked ("/>
            <Run Text="{Binding Blocked.Count, Mode=OneWay}"/>
            <Run Text=")"/>
          </TextBlock>
          <DataGrid ItemsSource="{Binding Blocked}" AutoGenerateColumns="False" IsReadOnly="True"
                    HeadersVisibility="Column" GridLinesVisibility="None"
                    CanUserAddRows="False" CanUserDeleteRows="False">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Datei" Binding="{Binding FileName}" Width="*"/>
              <DataGridTextColumn Header="Konsole" Binding="{Binding ConsoleKey}" Width="Auto"/>
              <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>
    </Grid>
  </DockPanel>
</UserControl>
