<UserControl x:Class="Romulus.UI.Wpf.Views.PipelineWorkbenchView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
    <StackPanel>
      <TextBlock Text="Pipeline Workbench" Style="{StaticResource SectionHeader}" Margin="0,0,0,4"/>
      <TextBlock Text="Conversion, Sorting und Batch-Aktionen aus einem Bereich."
                 Style="{StaticResource CaptionText}" Margin="0,0,0,16"/>

      <Border Style="{StaticResource SectionCard}" Margin="0,0,0,12"
              Visibility="{Binding Shell.SelectedSubTab, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Conversion}">
        <StackPanel>
          <TextBlock Text="Conversion" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}"/>
          <TextBlock Text="Plane und starte formatbezogene Conversion-Laeufe." Style="{StaticResource CaptionText}" Margin="0,6,0,12"/>
          <WrapPanel>
            <Button Command="{Binding PresetConvertCommand}" Content="Preset: Convert" Margin="0,0,8,8" MinWidth="160"/>
            <Button Command="{Binding ConvertOnlyCommand}" Content="Convert Only starten" Margin="0,0,8,8" MinWidth="170"/>
          </WrapPanel>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource SectionCard}" Margin="0,0,0,12"
              Visibility="{Binding Shell.SelectedSubTab, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Sorting}">
        <StackPanel>
          <TextBlock Text="Sorting" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}"/>
          <TextBlock Text="Starte geordnete Sortierung mit Preview oder Preset." Style="{StaticResource CaptionText}" Margin="0,6,0,12"/>
          <WrapPanel>
            <Button Command="{Binding PresetFullSortCommand}" Content="Preset: Full Sort" Margin="0,0,8,8" MinWidth="160"/>
            <Button Command="{Binding QuickPreviewCommand}" Content="Safe Preview" Margin="0,0,8,8" MinWidth="140"/>
          </WrapPanel>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource SectionCard}" Margin="0,0,0,12"
              Visibility="{Binding Shell.SelectedSubTab, Converter={StaticResource StrEqualsToVis}, ConverterParameter=Batch}">
        <StackPanel>
          <TextBlock Text="Batch" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}"/>
          <TextBlock Text="Fuehre Batch-Lauf aus und oeffne direkt danach die Ergebnisse." Style="{StaticResource CaptionText}" Margin="0,6,0,12"/>
          <WrapPanel>
            <Button Command="{Binding RunCommand}" Content="Pipeline ausfuehren" Margin="0,0,8,8" MinWidth="170"/>
            <Button Command="{Binding OpenReportCommand}" Content="Report oeffnen" Margin="0,0,8,8" MinWidth="140"/>
          </WrapPanel>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
