<UserControl x:Class="Romulus.UI.Wpf.Views.AuditViewerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- T-W4-AUDIT-VIEWER-UI: Read-only Audit-Browser.
       Datenquelle: MainViewModel.AuditViewer (AuditViewerViewModel) -> IAuditViewerBackingService.
       Die View berechnet NICHTS selbst; sie ist reine Projektion. -->
  <DockPanel LastChildFill="True" DataContext="{Binding AuditViewer}">
    <!-- Header + Toolbar -->
    <Border DockPanel.Dock="Top" Style="{StaticResource SectionCard}" Margin="20,16,20,8">
      <StackPanel>
        <TextBlock Text="Audit-Viewer" Style="{StaticResource SectionHeader}"/>
        <TextBlock
          Text="Alle Audit-Runs unter dem Audit-Root. Sidecar-Verifikation und Ledger-Status sichtbar. Read-only — Rollback nur ueber bestaetigten Confirm-Token."
          Style="{StaticResource CaptionText}" Margin="0,4,0,12" TextWrapping="Wrap"/>
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="Audit-Root:" VerticalAlignment="Center" Margin="0,0,8,0"
                     Foreground="{DynamicResource BrushTextMuted}"/>
          <TextBox Text="{Binding AuditRoot, UpdateSourceTrigger=PropertyChanged}"
                   MinWidth="320" Margin="0,0,12,0"/>
          <Button Content="Aktualisieren" Command="{Binding RefreshCommand}"
                  Style="{StaticResource PrimaryButton}"/>
          <Button Content="Rollback (CONFIRM)" Command="{Binding RollbackCommand}"
                  Style="{StaticResource DangerButton}" Margin="12,0,0,0"/>
        </StackPanel>
        <TextBlock Text="{Binding LastError}" Foreground="{DynamicResource BrushDanger}"
                   Margin="0,8,0,0"
                   Visibility="{Binding LastError, Converter={StaticResource StringNotEmptyToVisibility}}"/>
      </StackPanel>
    </Border>

    <!-- Master / Detail -->
    <Grid Margin="20,8,20,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="2*"/>
        <ColumnDefinition Width="3*"/>
      </Grid.ColumnDefinitions>

      <!-- Master: Run-Liste -->
      <Border Grid.Column="0" Style="{StaticResource SectionCard}" Margin="0,0,8,0">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="Runs" Style="{StaticResource SubsectionHeader}"
                     Margin="0,0,0,8"/>
          <DataGrid ItemsSource="{Binding Runs}" SelectedItem="{Binding SelectedRun, Mode=TwoWay}"
                    AutoGenerateColumns="False" IsReadOnly="True"
                    HeadersVisibility="Column" GridLinesVisibility="None"
                    CanUserAddRows="False" CanUserDeleteRows="False"
                    CanUserReorderColumns="False" CanUserResizeRows="False">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Datei" Binding="{Binding FileName}" Width="*"/>
              <DataGridTextColumn Header="RunId" Binding="{Binding RunId}" Width="Auto"/>
              <DataGridTextColumn Header="Zeilen" Binding="{Binding RowCount}" Width="Auto"/>
              <DataGridTextColumn Header="Geaendert" Binding="{Binding LastModifiedUtc, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="Auto"/>
              <DataGridCheckBoxColumn Header="Sidecar" Binding="{Binding HasSidecar}" Width="Auto"/>
              <DataGridCheckBoxColumn Header="Sig OK" Binding="{Binding IsSidecarValid}" Width="Auto"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>

      <!-- Detail: Rows + Sidecar -->
      <Border Grid.Column="1" Style="{StaticResource SectionCard}" Margin="8,0,0,0">
        <DockPanel>
          <Border DockPanel.Dock="Top" Margin="0,0,0,8">
            <StackPanel>
              <TextBlock Text="Sidecar" Style="{StaticResource SubsectionHeader}"/>
              <TextBlock Margin="0,4,0,0">
                <Run Text="Pfad: " Foreground="{DynamicResource BrushTextMuted}"/>
                <Run Text="{Binding SelectedSidecar.SidecarPath, Mode=OneWay, FallbackValue='-'}"/>
              </TextBlock>
              <TextBlock>
                <Run Text="Zeilen (Sidecar): " Foreground="{DynamicResource BrushTextMuted}"/>
                <Run Text="{Binding SelectedSidecar.DeclaredRowCount, Mode=OneWay, FallbackValue='-'}"/>
              </TextBlock>
              <TextBlock>
                <Run Text="Signatur gueltig: " Foreground="{DynamicResource BrushTextMuted}"/>
                <Run Text="{Binding SelectedSidecar.IsSignatureValid, Mode=OneWay, FallbackValue='-'}"/>
              </TextBlock>
            </StackPanel>
          </Border>

          <TextBlock DockPanel.Dock="Top" Text="Zeilen" Style="{StaticResource SubsectionHeader}"
                     Margin="0,0,0,8"/>
          <DataGrid ItemsSource="{Binding SelectedRunRows}"
                    AutoGenerateColumns="False" IsReadOnly="True"
                    HeadersVisibility="Column" GridLinesVisibility="None"
                    CanUserAddRows="False" CanUserDeleteRows="False"
                    CanUserReorderColumns="False" CanUserResizeRows="False">
            <DataGrid.Columns>
              <DataGridTextColumn Header="#" Binding="{Binding LineNumber}" Width="Auto"/>
              <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="Auto"/>
              <DataGridTextColumn Header="Kategorie" Binding="{Binding Category}" Width="Auto"/>
              <DataGridTextColumn Header="Alt" Binding="{Binding OldPath}" Width="*"/>
              <DataGridTextColumn Header="Neu" Binding="{Binding NewPath}" Width="*"/>
              <DataGridTextColumn Header="Hash" Binding="{Binding Hash}" Width="Auto"/>
              <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="Auto"/>
              <DataGridTextColumn Header="Zeit" Binding="{Binding Timestamp}" Width="Auto"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>
    </Grid>
  </DockPanel>
</UserControl>
