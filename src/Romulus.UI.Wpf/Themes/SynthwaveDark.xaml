<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<!-- ═══ SYNTHWAVE DARK ═══════════════════════════════════════════════════
  Neon-soaked retro palette. Colours only — templates in _ControlTemplates.xaml.
  ═══════════════════════════════════════════════════════════════════════ -->

    <!-- ── Core Surfaces ──────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BrushBackground"   Color="#0D0D1F"/>
    <SolidColorBrush x:Key="BrushSurface"      Color="#1A1A3A"/>
    <SolidColorBrush x:Key="BrushSurfaceAlt"   Color="#13133A"/>
    <SolidColorBrush x:Key="BrushSurfaceLight" Color="#252550"/>

    <!-- ── Accent ─────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BrushAccentCyan"   Color="#00F5FF"/>
    <SolidColorBrush x:Key="BrushAccentPurple" Color="#BF00FF"/>

    <!-- ── Semantic ───────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BrushDanger"       Color="#FF0044"/>
    <SolidColorBrush x:Key="BrushSuccess"      Color="#00FF88"/>
    <SolidColorBrush x:Key="BrushWarning"      Color="#FFB700"/>

    <!-- ── Text ───────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BrushTextPrimary"  Color="#E8E8F8"/>
    <!-- UX-Q2: #9999CC→#A0A0D0. Hebt Muted-Kontrast auf SurfaceLight #252550
         von 5.14:1 auf 5.6:1 (WCAG AA bei kleinen Schriftgroessen sicherer).
         Auf Background #0D0D1F bleibt Ratio bei 7.5:1 (AAA). -->
    <SolidColorBrush x:Key="BrushTextMuted"    Color="#A0A0D0"/>
    <SolidColorBrush x:Key="BrushBorder"       Color="#2D2D5A"/>

    <!-- ── Semantic Backgrounds ──────────────────────────────────────── -->
    <SolidColorBrush x:Key="BrushDangerBg"  Color="#1A0A10"/>
    <SolidColorBrush x:Key="BrushSuccessBg" Color="#0A1A12"/>
    <SolidColorBrush x:Key="BrushInfoBg"    Color="#0A0A2A"/>
    <SolidColorBrush x:Key="BrushWarningBg" Color="#2B1E05"/>

    <!-- ── Interaction ───────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BrushButtonPressed"   Color="#00F5FF22"/>
    <SolidColorBrush x:Key="BrushInputSelection"  Color="#00F5FF44"/>
    <SolidColorBrush x:Key="BrushBorderHover"     Color="#4040A0"/>
    <SolidColorBrush x:Key="BrushPrimaryBg"       Color="#00F5FF33"/>
    <SolidColorBrush x:Key="BrushTextOnAccent"    Color="#FFFFFF"/>

    <!-- D6 (UX-Redesign Phase 3): Retro-Glow fuer Akzent-Komponenten.
         Wird von CommandBar-Logo via DynamicResource gezogen; Konsument ist
         fuer ReduceMotion-Respekt zustaendig (DataTrigger auf Shell.ReduceMotion). -->
    <DropShadowEffect x:Key="EffectAccentGlow" Color="#00F5FF" BlurRadius="14" ShadowDepth="0" Opacity="0.75"/>
    <SolidColorBrush x:Key="BrushPrimaryHover"    Color="#00F5FF55"/>
    <SolidColorBrush x:Key="BrushPrimaryActive"   Color="#00F5FF77"/>
    <SolidColorBrush x:Key="BrushDangerHover"     Color="#FF004422"/>
    <SolidColorBrush x:Key="BrushWarningHover"    Color="#FFB70022"/>
    <SolidColorBrush x:Key="BrushScrimOverlay"    Color="#CC0D0D1F"/>

</ResourceDictionary>
