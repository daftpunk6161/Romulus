<UserControl x:Class="RomCleanup.UI.Wpf.Views.ConfigFiltersView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
  <!-- Extracted from SettingsView "Filter" section -->
  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
    <StackPanel>
      <TextBlock Text="{Binding Loc[Settings.SectionFilters]}" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
      <TextBlock Text="{Binding Loc[Settings.LabelFileTypes]}" Foreground="{DynamicResource BrushTextMuted}" FontSize="11" Margin="0,4,0,4"/>
      <ItemsControl ItemsSource="{Binding ExtensionFiltersView}" Margin="0,0,0,16">
        <ItemsControl.GroupStyle>
          <GroupStyle>
            <GroupStyle.HeaderTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Name}" Style="{StaticResource CategoryHeader}"/>
              </DataTemplate>
            </GroupStyle.HeaderTemplate>
            <GroupStyle.Panel>
              <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
            </GroupStyle.Panel>
          </GroupStyle>
        </ItemsControl.GroupStyle>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <CheckBox Content="{Binding Extension}" IsChecked="{Binding IsChecked}"
                      ToolTip="{Binding ToolTip}" Margin="0,0,12,4"
                      AutomationProperties.Name="{Binding Extension, StringFormat='Dateityp {0} filtern'}"/>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <TextBlock Text="{Binding Loc[Settings.LabelConsoles]}" Foreground="{DynamicResource BrushTextMuted}" FontSize="11" Margin="0,4,0,4"/>
      <TextBox Text="{Binding ConsoleFilterText, UpdateSourceTrigger=PropertyChanged}"
               Margin="0,0,0,8" Padding="6,4"
               AutomationProperties.Name="{Binding Loc[Settings.ConsoleSearchLabel]}"
               ToolTip="{Binding Loc[Settings.ConsoleSearchTip]}"/>
      <ListBox ItemsSource="{Binding ConsoleFiltersView}"
               MaxHeight="260"
               VirtualizingPanel.IsVirtualizing="True"
               VirtualizingPanel.VirtualizationMode="Recycling"
               ScrollViewer.CanContentScroll="True"
               ScrollViewer.VerticalScrollBarVisibility="Auto"
               BorderThickness="0" Background="Transparent"
               AutomationProperties.Name="{Binding Loc[Settings.LabelConsoles]}">
        <ListBox.GroupStyle>
          <GroupStyle>
            <GroupStyle.HeaderTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Name}" Style="{StaticResource CategoryHeader}"/>
              </DataTemplate>
            </GroupStyle.HeaderTemplate>
          </GroupStyle>
        </ListBox.GroupStyle>
        <ListBox.ItemTemplate>
          <DataTemplate>
            <CheckBox Content="{Binding DisplayName}"
                      IsChecked="{Binding IsChecked, Mode=TwoWay}"
                      Margin="0,0,12,4"
                      AutomationProperties.Name="{Binding DisplayName, StringFormat='Konsole {0} filtern'}"/>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </StackPanel>
  </ScrollViewer>
</UserControl>
