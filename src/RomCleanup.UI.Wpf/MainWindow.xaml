<Window x:Class="RomCleanup.UI.Wpf.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
    xmlns:conv="clr-namespace:RomCleanup.UI.Wpf.Converters"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    Title="ROM Cleanup"
    Width="960" Height="720"
    MinWidth="800" MinHeight="600"
    WindowStartupLocation="CenterScreen"
    FontFamily="Segoe UI" FontSize="13"
    Background="{DynamicResource BrushBackground}" Foreground="{DynamicResource BrushTextPrimary}"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True">

  <Window.Resources>
    <!-- ═══ CONVERTERS ════════════════════════════════════════════════════ -->
    <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
    <conv:StatusLevelToBrushConverter x:Key="StatusToBrush"/>
    <conv:LogLevelToBrushConverter x:Key="LogLevelToBrush"/>
    <conv:StepActiveBrushConverter x:Key="StepToBrush"/>

    <!-- ═══ DATA TEMPLATES ════════════════════════════════════════════════ -->
    <DataTemplate x:Key="LogEntryTemplate">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="&#x2022; " Foreground="{Binding Level, Converter={StaticResource LogLevelToBrush}}"/>
        <TextBlock Text="{Binding Text}" Foreground="{Binding Level, Converter={StaticResource LogLevelToBrush}}"
                   FontFamily="Consolas" FontSize="11"/>
      </StackPanel>
    </DataTemplate>
    <DataTemplate x:Key="RootItemTemplate">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="&#xE8B7; " FontFamily="Segoe MDL2 Assets" FontSize="14"
                   Foreground="{DynamicResource BrushAccentCyan}" VerticalAlignment="Center" Margin="{DynamicResource SpaceRightSM}"/>
        <TextBlock Text="{Binding}" Foreground="{DynamicResource BrushTextPrimary}" VerticalAlignment="Center"/>
      </StackPanel>
    </DataTemplate>
  </Window.Resources>

  <Window.InputBindings>
    <KeyBinding Key="F5" Command="{Binding RunCommand}"/>
    <KeyBinding Key="Escape" Command="{Binding CancelCommand}"/>
    <KeyBinding Key="R" Modifiers="Control" Command="{Binding OpenReportCommand}"/>
    <KeyBinding Key="Z" Modifiers="Control" Command="{Binding RollbackCommand}"/>
    <KeyBinding Key="O" Modifiers="Control" Command="{Binding AddRootCommand}"/>
    <KeyBinding Key="L" Modifiers="Control" Command="{Binding ClearLogCommand}"/>
    <KeyBinding Key="T" Modifiers="Control" Command="{Binding ThemeToggleCommand}"/>
    <KeyBinding Key="G" Modifiers="Control" Command="{Binding GameKeyPreviewCommand}"/>
    <KeyBinding Key="D1" Modifiers="Control" Command="{Binding PresetSafeDryRunCommand}"/>
    <KeyBinding Key="D2" Modifiers="Control" Command="{Binding PresetFullSortCommand}"/>
  </Window.InputBindings>

  <DockPanel LastChildFill="True">

    <!-- ═══ TOP STATUS BAR ════════════════════════════════════════════════ -->
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource BrushSurfaceAlt}" BorderBrush="{DynamicResource BrushBorder}"
            BorderThickness="0,0,0,1" Padding="{DynamicResource PaddingBar}">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
          <ComboBox x:Name="cmbQuickProfile" Width="160" Margin="{DynamicResource SpaceDotInline}"
                    ToolTip="Konfigurationsprofil schnell wechseln" IsEditable="False"
                    AutomationProperties.Name="Konfigurationsprofil">
            <ComboBoxItem Content="Standard" IsSelected="True"/>
            <ComboBoxItem Content="Disc (CHD)"/>
            <ComboBoxItem Content="Cartridge (ZIP)"/>
            <ComboBoxItem Content="Gemischt"/>
          </ComboBox>
          <Button Command="{Binding OpenReportCommand}" ToolTip="Letzten Bericht öffnen (Ctrl+R)" Margin="4,0,8,0"
                  AutomationProperties.Name="Letzten Bericht öffnen"
                  AutomationProperties.AcceleratorKey="Ctrl+R">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A7;" FontSize="14" Margin="{DynamicResource SpaceRightSM}"/>
              <TextBlock Text="_Bericht"/>
            </StackPanel>
          </Button>
        </StackPanel>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" ClipToBounds="True">
          <TextBlock Text="ROM CLEANUP" Style="{StaticResource TitleText}"
                     VerticalAlignment="Center" Margin="8,0,24,0"/>
          <Rectangle Width="1" Height="16" Fill="{DynamicResource BrushBorder}" VerticalAlignment="Center" Margin="{DynamicResource SpaceRightSM}"/>
          <!-- Status dots bound to ViewModel StatusLevel via converter -->
          <Ellipse Width="12" Height="12" VerticalAlignment="Center" Margin="{DynamicResource SpaceDotInline}"
                   Fill="{Binding RootsStatusLevel, Converter={StaticResource StatusToBrush}}"
                   ToolTip="ROM-Ordner: Grün = konfiguriert, Grau = fehlt"/>
          <TextBlock Text="{Binding StatusRoots}" Foreground="{DynamicResource BrushTextMuted}"
                     VerticalAlignment="Center" Margin="{DynamicResource SpaceRightMD}" FontSize="11"/>
          <Ellipse Width="12" Height="12" VerticalAlignment="Center" Margin="{DynamicResource SpaceDotInline}"
                   Fill="{Binding ToolsStatusLevel, Converter={StaticResource StatusToBrush}}"
                   ToolTip="Tools: Grün = chdman/7z gefunden, Grau = fehlt"/>
          <TextBlock Text="{Binding StatusTools}" Foreground="{DynamicResource BrushTextMuted}"
                     VerticalAlignment="Center" Margin="{DynamicResource SpaceRightMD}" FontSize="11"/>
          <Ellipse Width="12" Height="12" VerticalAlignment="Center" Margin="{DynamicResource SpaceDotInline}"
                   Fill="{Binding DatStatusLevel, Converter={StaticResource StatusToBrush}}"
                   ToolTip="DAT-Verifizierung: Grün = aktiv, Grau = deaktiviert"/>
          <TextBlock Text="{Binding StatusDat}" Foreground="{DynamicResource BrushTextMuted}"
                     VerticalAlignment="Center" FontSize="11"/>
          <Rectangle Width="1" Height="16" Fill="{DynamicResource BrushBorder}" VerticalAlignment="Center" Margin="{DynamicResource SpaceDivider}"/>
          <Ellipse Width="14" Height="14" VerticalAlignment="Center" Margin="{DynamicResource SpaceDotInline}"
                   Fill="{Binding ReadyStatusLevel, Converter={StaticResource StatusToBrush}}"
                   ToolTip="Gesamtstatus: Grün = startbereit, Gelb = Warnung, Rot = blockiert"/>
          <TextBlock Text="{Binding StatusReady}" Foreground="{DynamicResource BrushTextMuted}"
                     VerticalAlignment="Center" FontSize="11"
                     AutomationProperties.Name="Gesamtstatus" AutomationProperties.LiveSetting="Polite"/>
          <Rectangle Width="1" Height="16" Fill="{DynamicResource BrushBorder}" VerticalAlignment="Center" Margin="{DynamicResource SpaceDivider}"/>
          <TextBlock Text="{Binding StatusRuntime}" Foreground="{DynamicResource BrushTextMuted}"
                     VerticalAlignment="Center" FontSize="11"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- ═══ FOOTER ACTION BAR ═════════════════════════════════════════════ -->
    <Border DockPanel.Dock="Bottom"
            Background="{DynamicResource BrushSurfaceAlt}" BorderBrush="{DynamicResource BrushBorder}"
            BorderThickness="0,1,0,0" Padding="{DynamicResource PaddingBar}">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
          <ProgressBar MinWidth="120" Width="200" Height="8" Maximum="100"
                       Value="{Binding Progress}" Margin="{DynamicResource SpaceLeftSM}" VerticalAlignment="Center"
                       AutomationProperties.Name="Fortschritt" AutomationProperties.LiveSetting="Polite"/>
          <TextBlock Text="{Binding ProgressText}" Foreground="{DynamicResource BrushTextMuted}"
                     VerticalAlignment="Center" FontSize="11" Margin="{DynamicResource SpaceLeftSM}"
                     AutomationProperties.Name="Fortschrittstext" AutomationProperties.LiveSetting="Polite"/>
        </StackPanel>
        <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
          <!-- Start -->
          <Button Command="{Binding RunCommand}" Style="{StaticResource PrimaryButton}"
                  Width="140" Height="52" Margin="{DynamicResource SpaceRightXS}"
                  ToolTip="Sortierung starten (F5)" AutomationProperties.Name="Sortierung starten"
                  AutomationProperties.AcceleratorKey="F5" TabIndex="1">
            <StackPanel HorizontalAlignment="Center">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE768;" FontSize="20" HorizontalAlignment="Center"/>
              <TextBlock Text="_Starten" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>
          </Button>
          <!-- Cancel -->
          <Button Command="{Binding CancelCommand}" Style="{StaticResource DangerButton}"
                  Width="60" Height="52" Margin="{DynamicResource SpaceRightXS}"
                  AutomationProperties.AcceleratorKey="Esc"
                  ToolTip="Lauf abbrechen (Esc)" AutomationProperties.Name="Lauf abbrechen" TabIndex="2">
            <StackPanel HorizontalAlignment="Center">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE71A;" FontSize="20" HorizontalAlignment="Center"/>
              <TextBlock Text="S_topp" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>
          </Button>
          <Rectangle Width="1" Height="40" Fill="{DynamicResource BrushBorder}" VerticalAlignment="Center" Margin="{DynamicResource SpaceDivider}"/>
          <!-- Rollback -->
          <Button Command="{Binding RollbackCommand}"
                  Width="110" Height="52" Margin="{DynamicResource SpaceRightXS}"
                  BorderBrush="{DynamicResource BrushAccentPurple}" Foreground="{DynamicResource BrushAccentPurple}"
                  AutomationProperties.AcceleratorKey="Ctrl+Z"
                  Background="{DynamicResource BrushDangerBg}" BorderThickness="2"
                  ToolTip="Letzten Lauf rückgängig machen (Ctrl+Z)" AutomationProperties.Name="Letzten Lauf rückgängig machen" TabIndex="3">
            <StackPanel HorizontalAlignment="Center">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE777;" FontSize="20" HorizontalAlignment="Center"/>
              <TextBlock Text="_Rückgängig" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>
          </Button>
          <Rectangle Width="1" Height="40" Fill="{DynamicResource BrushBorder}" VerticalAlignment="Center" Margin="{DynamicResource SpaceDivider}"/>
          <TextBlock Text="{Binding BusyHint}" Style="{StaticResource CaptionText}"
                     VerticalAlignment="Center" Margin="4,0"/>
        </WrapPanel>
      </DockPanel>
    </Border>

    <!-- ═══ MAIN TABCONTROL ═══════════════════════════════════════════════ -->
    <TabControl x:Name="tabMain" Margin="0">

      <!-- ═══ SORTIEREN ═══════════════════════════════════════════════════ -->
      <TabItem Header="Sortieren">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
          <StackPanel>

            <!-- Step Indicator -->
            <Border Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="{DynamicResource SpaceBottomMD}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                  <Ellipse x:Name="stepDot1" Width="22" Height="22" Stroke="{DynamicResource BrushBorder}"
                           StrokeThickness="2" Fill="{Binding CurrentStep, Converter={StaticResource StepToBrush}, ConverterParameter=1}" VerticalAlignment="Center" Margin="{DynamicResource SpaceRightSM}"/>
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="1 · Ordner" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                    <TextBlock Text="{Binding StepLabel1}" Style="{StaticResource CaptionText}"/>
                  </StackPanel>
                </StackPanel>
                <Border Grid.Column="1" Height="2" Width="32" VerticalAlignment="Center"
                        Background="{Binding CurrentStep, Converter={StaticResource StepToBrush}, ConverterParameter=2}" Margin="4,0"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                  <Ellipse x:Name="stepDot2" Width="22" Height="22" Stroke="{DynamicResource BrushBorder}"
                           StrokeThickness="2" Fill="{Binding CurrentStep, Converter={StaticResource StepToBrush}, ConverterParameter=2}" VerticalAlignment="Center" Margin="{DynamicResource SpaceRightSM}"/>
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="2 · Optionen" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                    <TextBlock Text="{Binding StepLabel2}" Style="{StaticResource CaptionText}"/>
                  </StackPanel>
                </StackPanel>
                <Border Grid.Column="3" Height="2" Width="32" VerticalAlignment="Center"
                        Background="{Binding CurrentStep, Converter={StaticResource StepToBrush}, ConverterParameter=3}" Margin="4,0"/>
                <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Center">
                  <Ellipse x:Name="stepDot3" Width="22" Height="22" Stroke="{DynamicResource BrushBorder}"
                           StrokeThickness="2" Fill="{Binding CurrentStep, Converter={StaticResource StepToBrush}, ConverterParameter=3}" VerticalAlignment="Center" Margin="{DynamicResource SpaceRightSM}"/>
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="3 · Starten" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource BrushTextMuted}"/>
                    <TextBlock Text="{Binding StepLabel3}" Style="{StaticResource CaptionText}"
                               AutomationProperties.Name="Aktueller Schritt" AutomationProperties.LiveSetting="Polite"/>
                  </StackPanel>
                </StackPanel>
              </Grid>
            </Border>

            <!-- Quick-Start Presets -->
            <Border Style="{StaticResource SectionCard}" Margin="{DynamicResource SpaceBottomSM}">
              <StackPanel>
                <TextBlock Text="QUICK-START" Style="{StaticResource SectionHeader}"/>
                <WrapPanel>
                  <Button Command="{Binding PresetSafeDryRunCommand}" Width="190" Height="48" Margin="0,0,8,4"
                          ToolTip="Sicherer DryRun: Nur prüfen, nichts verschieben" AutomationProperties.Name="Preset: Sicherer DryRun">
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Text="Sicherer DryRun" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                      <TextBlock Text="Nur prüfen, nichts ändern" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                  <Button Command="{Binding PresetFullSortCommand}" Width="190" Height="48" Margin="0,0,8,4"
                          ToolTip="Volle Sortierung: Alle Regionen, Standard-Regeln, DryRun aktiv" AutomationProperties.Name="Preset: Volle Sortierung">
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Text="Volle Sortierung" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                      <TextBlock Text="Alle Regionen, Standard-Regeln" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                  <Button Command="{Binding PresetConvertCommand}" Width="190" Height="48" Margin="0,0,8,4"
                          ToolTip="Konvertierung: Formate nach Move optimieren (CHD/RVZ)" AutomationProperties.Name="Preset: Konvertierung">
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Text="Konvertierung" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                      <TextBlock Text="Formate optimieren (CHD/RVZ)" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                </WrapPanel>
              </StackPanel>
            </Border>

            <!-- Mode Toggle (UX-006: prominent segmented control) -->
            <Border CornerRadius="6" BorderBrush="{DynamicResource BrushAccentCyan}"
                    BorderThickness="1.5" Margin="{DynamicResource SpaceBottomSM}" HorizontalAlignment="Left"
                    Background="{DynamicResource BrushSurface}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <RadioButton Grid.Column="0" GroupName="UiMode"
                             IsChecked="{Binding IsSimpleMode}" Padding="16,8" MinWidth="120" Cursor="Hand"
                             ToolTip="Vereinfachte Ansicht: nur die wichtigsten 4 Optionen"
                             AutomationProperties.Name="Einfacher Modus">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8FC;" FontSize="14"
                               VerticalAlignment="Center" Margin="{DynamicResource SpaceRightSM}"/>
                    <TextBlock Text="_Einfach" FontWeight="SemiBold" VerticalAlignment="Center"/>
                  </StackPanel>
                </RadioButton>
                <RadioButton Grid.Column="1" GroupName="UiMode"
                             IsChecked="{Binding IsExpertMode, Mode=OneWay}" Padding="16,8" MinWidth="120" Cursor="Hand"
                             ToolTip="Alle Konfigurationsoptionen anzeigen (Regionen, Filter, Konvertierung)"
                             AutomationProperties.Name="Experten-Modus">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" FontSize="14"
                               VerticalAlignment="Center" Margin="{DynamicResource SpaceRightSM}"/>
                    <TextBlock Text="E_xperte" FontWeight="SemiBold" VerticalAlignment="Center"/>
                  </StackPanel>
                </RadioButton>
              </Grid>
            </Border>

            <!-- ROM Directories -->
            <Border Style="{StaticResource SectionCard}">
              <StackPanel>
                <TextBlock Text="ROM-VERZEICHNISSE" Style="{StaticResource SectionHeader}"/>
                <Grid Margin="{DynamicResource SpaceBottomXS}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <Grid Grid.Column="0">
                    <ListBox x:Name="listRoots" MinHeight="60" MaxHeight="280" Margin="{DynamicResource SpaceRightSM}"
                             ItemsSource="{Binding Roots}"
                             SelectedItem="{Binding SelectedRoot}"
                             AllowDrop="True"
                             ItemTemplate="{StaticResource RootItemTemplate}"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             ScrollViewer.CanContentScroll="True"
                             ToolTip="ROM-Ordner hier hineinziehen (Drag &amp; Drop)"
                             TabIndex="10"
                             AutomationProperties.Name="ROM-Verzeichnisliste">
                      <ListBox.InputBindings>
                        <KeyBinding Key="Delete" Command="{Binding RemoveRootCommand}"/>
                      </ListBox.InputBindings>
                    </ListBox>
                    <!-- Empty-State Overlay -->
                    <Border IsHitTestVisible="False" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Margin="{DynamicResource SpaceRightSM}"
                            Visibility="{Binding RootsStatusLevel, Converter={StaticResource InverseBoolToVis}, ConverterParameter=Ok}">
                      <Border.Style>
                        <Style TargetType="Border">
                          <Setter Property="Visibility" Value="Collapsed"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding Roots.Count}" Value="0">
                              <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Border.Style>
                      <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                                   Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center"
                                   Margin="{DynamicResource SpaceBottomSM}" Opacity="0.6"/>
                        <TextBlock Text="ROM-Ordner hierher ziehen" FontSize="12"
                                   Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center"/>
                        <TextBlock Text="oder mit '+' hinzufügen" Style="{StaticResource CaptionText}"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                      </StackPanel>
                    </Border>
                  </Grid>
                  <StackPanel Grid.Column="1" VerticalAlignment="Top" Width="118">
                    <Button Command="{Binding AddRootCommand}" Content="＋ _Hinzufügen" Margin="{DynamicResource SpaceBottomXS}" HorizontalAlignment="Stretch"
                            ToolTip="Neuen ROM-Ordner zur Liste hinzufügen" AutomationProperties.Name="ROM-Ordner hinzufügen"
                            TabIndex="11"/>
                    <Button Command="{Binding RemoveRootCommand}" Content="－ _Entfernen" Margin="{DynamicResource SpaceBottomXS}" HorizontalAlignment="Stretch"
                            ToolTip="Ausgewählten ROM-Ordner entfernen (Entf)" AutomationProperties.Name="ROM-Ordner entfernen"
                            TabIndex="12"/>
                  </StackPanel>
                </Grid>
              </StackPanel>
            </Border>

            <!-- Simple Mode Panel -->
            <Border Style="{StaticResource SectionCard}"
                    Visibility="{Binding IsSimpleMode, Converter={StaticResource BoolToVis}}">
              <StackPanel>
                <TextBlock Text="SCHNELLSTART" Style="{StaticResource SectionHeader}" Margin="{DynamicResource SpaceBottomSM}"/>
                <StackPanel Margin="{DynamicResource SpaceBottomSM}">
                  <TextBlock Text="Region:" Margin="{DynamicResource SpaceBottomXS}" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextMuted}"/>
                  <ComboBox x:Name="cmbEinfachRegion" Width="220" HorizontalAlignment="Left"
                            SelectedIndex="{Binding SimpleRegionIndex}"
                            ToolTip="Bevorzugte Region: ROMs dieser Region werden bei Duplikaten bevorzugt."
                            AutomationProperties.Name="Bevorzugte Region">
                    <ComboBoxItem Content="Europa (EU)"/>
                    <ComboBoxItem Content="Nordamerika (US)"/>
                    <ComboBoxItem Content="Japan (JP)"/>
                    <ComboBoxItem Content="Weltweit (Alle)"/>
                  </ComboBox>
                </StackPanel>
                <StackPanel Margin="{DynamicResource SpaceBottomSM}">
                  <TextBlock Text="Was soll passieren?" Margin="{DynamicResource SpaceBottomXS}" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextMuted}"/>
                  <CheckBox Content="Duplikate erkennen und aussortieren" IsChecked="{Binding SimpleDupes}" Margin="0,2"
                            ToolTip="Erkennt ROMs mit gleichem Spielnamen und behält nur die beste Version (Region, Format, Revision)."/>
                  <CheckBox Content="Junk-Dateien entfernen (Demos, Betas, Hacks)" IsChecked="{Binding SimpleJunk}" Margin="0,2"
                            ToolTip="Verschiebt Demos, Betas, Prototypen, Hacks und Homebrew in den Papierkorb-Ordner."/>
                  <CheckBox Content="In Konsolen-Ordner sortieren" IsChecked="{Binding SimpleSort}" Margin="0,2"
                            ToolTip="Sortiert ROMs automatisch in Unterordner nach erkannter Konsole (z.B. SNES, PS1, GBA)."/>
                </StackPanel>
                <TextBlock Text="Ordner oben hinzufügen, dann unten auf 'Sortierung starten' klicken."
                           Style="{StaticResource CaptionText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>

            <!-- Expert Mode Panel -->
            <StackPanel Visibility="{Binding IsExpertMode, Converter={StaticResource BoolToVis}}">
              <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                  <TextBlock Text="OPTIONEN" Style="{StaticResource SectionHeader}"/>
                  <WrapPanel>
                    <CheckBox Content="Nur Vorschau (Dry Run)" Margin="0,4,24,4"
                              IsChecked="{Binding DryRun}" Foreground="{DynamicResource BrushWarning}"
                              ToolTip="Es werden keine Dateien verschoben; nur Analyse + Bericht."/>
                    <CheckBox Content="Winner nach Move konvertieren (CHD/RVZ/ZIP)" Margin="0,4,24,4"
                              IsChecked="{Binding ConvertEnabled}"
                              ToolTip="Aktiviert Format-Konvertierung im Move-Lauf."/>
                  </WrapPanel>
                  <!-- Conflict Policy (UX-007: replaced YesNoCancel hack) -->
                  <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                    <TextBlock Text="Namenskollision:" VerticalAlignment="Center" Margin="{DynamicResource SpaceRightSM}"/>
                    <ComboBox Width="160" SelectedIndex="{Binding ConflictPolicyIndex, Mode=TwoWay}"
                              ToolTip="Wie Dateinamenkollisionen beim Verschieben behandelt werden sollen."
                              AutomationProperties.Name="Namenskollisions-Strategie">
                      <ComboBoxItem Content="Umbenennen (_1, _2 …)"/>
                      <ComboBoxItem Content="Überspringen"/>
                      <ComboBoxItem Content="Überschreiben"/>
                    </ComboBox>
                  </StackPanel>
                  <!-- DryRun Banner -->
                  <Border Margin="0,8,0,0" Padding="12,8"
                          Background="{DynamicResource BrushSuccessBg}" BorderBrush="{DynamicResource BrushSuccess}" BorderThickness="1"
                          CornerRadius="6"
                          Visibility="{Binding DryRun, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="DryRun aktiv: Es werden keine Dateien verschoben."
                                 Foreground="{DynamicResource BrushSuccess}" FontWeight="SemiBold" TextWrapping="Wrap"
                                 VerticalAlignment="Center"/>
                      <Button x:Name="btnStartMove" Content="▶ Jetzt als Move ausführen"
                              Margin="16,0,0,0" Padding="12,4" FontWeight="SemiBold"
                              Background="{DynamicResource BrushDangerBg}" Foreground="{DynamicResource BrushDanger}" BorderBrush="{DynamicResource BrushDanger}"
                              BorderThickness="1" Cursor="Hand"
                              Visibility="{Binding ShowStartMoveButton, Converter={StaticResource BoolToVis}}"
                              ToolTip="Startet den Lauf erneut im Move-Modus."
                              AutomationProperties.Name="Jetzt als Move ausführen"/>
                    </StackPanel>
                  </Border>
                  <!-- Move Complete Banner -->
                  <Border Margin="0,8,0,0" Padding="12,8"
                          Background="{DynamicResource BrushDangerBg}" BorderBrush="{DynamicResource BrushAccentPurple}" BorderThickness="1"
                          CornerRadius="6"
                          Visibility="{Binding ShowMoveCompleteBanner, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="Move abgeschlossen."
                                 Foreground="{DynamicResource BrushAccentPurple}" FontWeight="SemiBold" TextWrapping="Wrap"
                                 VerticalAlignment="Center"/>
                      <Button Command="{Binding RollbackCommand}" Content="&#xE777; Rückgängig machen"
                              FontFamily="Segoe MDL2 Assets, Segoe UI"
                              Margin="16,0,0,0" Padding="12,4" FontWeight="SemiBold"
                              Background="{DynamicResource BrushDangerBg}" Foreground="{DynamicResource BrushAccentPurple}"
                              BorderBrush="{DynamicResource BrushAccentPurple}" BorderThickness="1" Cursor="Hand"
                              ToolTip="Letzten Move-Lauf rückgängig machen (Ctrl+Z)"
                              AutomationProperties.Name="Letzten Move-Lauf rückgängig machen"/>
                    </StackPanel>
                  </Border>
                  <TextBlock Text="Tipp: Erweiterte Optionen findest du im Tab 'Einstellungen'."
                             Style="{StaticResource CaptionText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>
              </Border>

              <!-- RD-003: Region Preferences directly in Expert Sortieren tab -->
              <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                  <TextBlock Text="REGION-PRIORITÄT" Style="{StaticResource SectionHeader}"/>
                  <TextBlock Text="Aktivierte Regionen werden bei Duplikaten bevorzugt behalten."
                             Style="{StaticResource CaptionText}" Margin="{DynamicResource SpaceBottomSM}" TextWrapping="Wrap"/>
                  <WrapPanel>
                    <CheckBox Content="EU"    Margin="0,0,12,4" IsChecked="{Binding PreferEU}"    ToolTip="Europa (EUR/PAL)"/>
                    <CheckBox Content="US"    Margin="0,0,12,4" IsChecked="{Binding PreferUS}"    ToolTip="USA (NTSC)"/>
                    <CheckBox Content="WORLD" Margin="0,0,12,4" IsChecked="{Binding PreferWORLD}" ToolTip="World-/Export-Versionen"/>
                    <CheckBox Content="JP"    Margin="0,0,12,4" IsChecked="{Binding PreferJP}"    ToolTip="Japan"/>
                  </WrapPanel>
                  <Expander Header="Weitere Regionen" IsExpanded="False" Margin="0,2,0,0">
                    <WrapPanel Margin="0,4,0,0">
                      <CheckBox Content="DE"   Margin="0,0,12,4" IsChecked="{Binding PreferDE}"   ToolTip="Deutschland"/>
                      <CheckBox Content="FR"   Margin="0,0,12,4" IsChecked="{Binding PreferFR}"   ToolTip="Frankreich"/>
                      <CheckBox Content="IT"   Margin="0,0,12,4" IsChecked="{Binding PreferIT}"   ToolTip="Italien"/>
                      <CheckBox Content="ES"   Margin="0,0,12,4" IsChecked="{Binding PreferES}"   ToolTip="Spanien"/>
                      <CheckBox Content="AU"   Margin="0,0,12,4" IsChecked="{Binding PreferAU}"   ToolTip="Australien"/>
                      <CheckBox Content="ASIA" Margin="0,0,12,4" IsChecked="{Binding PreferASIA}" ToolTip="Asien"/>
                      <CheckBox Content="KR"   Margin="0,0,12,4" IsChecked="{Binding PreferKR}"   ToolTip="Südkorea"/>
                      <CheckBox Content="CN"   Margin="0,0,12,4" IsChecked="{Binding PreferCN}"   ToolTip="China"/>
                      <CheckBox Content="BR"   Margin="0,0,12,4" IsChecked="{Binding PreferBR}"   ToolTip="Brasilien"/>
                      <CheckBox Content="NL"   Margin="0,0,12,4" IsChecked="{Binding PreferNL}"   ToolTip="Niederlande"/>
                      <CheckBox Content="SE"   Margin="0,0,12,4" IsChecked="{Binding PreferSE}"   ToolTip="Schweden"/>
                      <CheckBox Content="SCAN" Margin="0,0,12,4" IsChecked="{Binding PreferSCAN}" ToolTip="Skandinavien"/>
                    </WrapPanel>
                  </Expander>
                </StackPanel>
              </Border>

              <!-- Danger Zone (collapsed — Move confirmation via styled dialog) -->
              <Expander Header="Move-Modus (Gefahr)" Foreground="{DynamicResource BrushDanger}" Margin="{DynamicResource SpaceTopLG}"
                        Visibility="Collapsed">
                <Border Background="{DynamicResource BrushDangerBg}" BorderBrush="{DynamicResource BrushDanger}" BorderThickness="1"
                        CornerRadius="8" Padding="12" Margin="0,8,0,0">
                  <StackPanel>
                    <TextBlock Text="⚠ GEFAHR: MOVE-MODUS" FontFamily="Consolas" FontWeight="Bold"
                               FontSize="10" Foreground="{DynamicResource BrushDanger}" Margin="{DynamicResource SpaceBottomSM}"/>
                    <TextBlock Text="Im Move-Modus werden Duplikate physisch verschoben. Stelle sicher, dass ein korrektes Backup existiert."
                               Foreground="{DynamicResource BrushDanger}" FontSize="11" TextWrapping="Wrap" Margin="{DynamicResource SpaceBottomSM}"/>
                    <CheckBox Content="Ich verstehe die Folgen – Move-Modus freischalten"
                              IsChecked="{Binding ConfirmMove}" Foreground="{DynamicResource BrushDanger}"/>
                  </StackPanel>
                </Border>
              </Expander>
            </StackPanel>

          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- ═══ ERGEBNIS (RD-001) ════════════════════════════════════════════ -->
      <!-- moved earlier — see above -->

      <!-- ═══ WERKZEUGE (RD-004: kategorisierte, filterbare Liste) ═════════ -->
      <TabItem Header="Werkzeuge">
        <DockPanel>
          <!-- Filter bar -->
          <Border DockPanel.Dock="Top" Background="{DynamicResource BrushSurfaceAlt}"
                  BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,0,1" Padding="12,8">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                         Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" Margin="{DynamicResource SpaceRightSM}"/>
              <TextBox Grid.Column="1" Text="{Binding ToolFilterText, UpdateSourceTrigger=PropertyChanged}"
                       MinWidth="200" VerticalAlignment="Center"
                       ToolTip="Werkzeuge filtern (Name, Kategorie, Beschreibung)"
                       AutomationProperties.Name="Werkzeuge-Filter"/>
              <TextBlock Grid.Column="2" Text="{Binding ToolItems.Count, StringFormat='{}{0} Werkzeuge'}"
                         Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" Margin="{DynamicResource SpaceLeftSM}" FontSize="11"/>
            </Grid>
          </Border>

          <!-- Categorized tool list -->
          <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
            <ItemsControl ItemsSource="{Binding ToolItemsView}">
              <ItemsControl.GroupStyle>
                <GroupStyle>
                  <GroupStyle.HeaderTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Name}" Style="{StaticResource SectionHeader}" Margin="0,16,0,6"/>
                    </DataTemplate>
                  </GroupStyle.HeaderTemplate>
                </GroupStyle>
              </ItemsControl.GroupStyle>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Margin="0,0,8,6" Padding="10,8" HorizontalContentAlignment="Left" MinWidth="220" MaxWidth="360"
                          Command="{Binding Command}"
                          ToolTip="{Binding Description}"
                          AutomationProperties.Name="{Binding DisplayName}"
                          Tag="{Binding Key}">
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                 Foreground="{DynamicResource BrushAccentCyan}" VerticalAlignment="Center" Margin="{DynamicResource SpaceRightSM}"/>
                      <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Text="{Binding Description}" Style="{StaticResource CaptionText}" TextTrimming="CharacterEllipsis" MaxWidth="260"/>
                      </StackPanel>
                    </StackPanel>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>
      </TabItem>

      <!-- ═══ EINSTELLUNGEN (RD-001/RD-002: Accordion statt verschachtelte Expander) ═ -->
      <TabItem Header="Einstellungen">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
          <StackPanel>

            <!-- Accordion Section: Sortieroptionen -->
            <Border Style="{StaticResource SectionCard}" Margin="{DynamicResource SpaceBottomSM}">
              <Expander Header="Sortieroptionen" IsExpanded="True">
                <StackPanel Margin="0,8,0,0">
                  <WrapPanel>
                    <CheckBox Content="Ordner nach Konsole strukturieren" Margin="0,4,24,4"
                              IsChecked="{Binding SortConsole}" ToolTip="Erstellt Unterordner pro Konsole"/>
                    <CheckBox Content="Offensichtliche Junk-Dateien stärker filtern" Margin="0,4,24,4"
                              IsChecked="{Binding AggressiveJunk}" ToolTip="Entfernt zusätzliche Beta/Proto/Sample-Dateien"/>
                    <CheckBox Content="Spielnamen vereinheitlichen" Margin="0,4,24,4"
                              IsChecked="{Binding AliasKeying}" ToolTip="Gleicht bekannte Namensvarianten auf denselben Titel ab"/>
                  </WrapPanel>
                </StackPanel>
              </Expander>
            </Border>

            <!-- Accordion Section: Dateityp- & Konsolen-Filter -->
            <Border Style="{StaticResource SectionCard}" Margin="{DynamicResource SpaceBottomSM}">
              <Expander Header="Dateityp- &amp; Konsolen-Filter" IsExpanded="False">
                <StackPanel Margin="0,8,0,0">
                  <TextBlock Text="Dateitypen (keine Auswahl = alle Dateitypen scannen):" Foreground="{DynamicResource BrushTextMuted}" FontSize="11" Margin="0,4,0,4"/>
                  <ItemsControl ItemsSource="{Binding ExtensionFiltersView}" Margin="{DynamicResource SpaceBottomSM}">
                    <ItemsControl.GroupStyle>
                      <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                          <DataTemplate>
                            <TextBlock Text="{Binding Name}" Style="{StaticResource CategoryHeader}"/>
                          </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                        <GroupStyle.Panel>
                          <ItemsPanelTemplate>
                            <WrapPanel/>
                          </ItemsPanelTemplate>
                        </GroupStyle.Panel>
                      </GroupStyle>
                    </ItemsControl.GroupStyle>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <CheckBox Content="{Binding Extension}" IsChecked="{Binding IsChecked}"
                                  ToolTip="{Binding ToolTip}" Margin="0,0,12,4"/>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <TextBlock Text="Konsolen (keine Auswahl = alle Konsolen):" Foreground="{DynamicResource BrushTextMuted}" FontSize="11" Margin="0,4,0,4"/>
                  <ItemsControl ItemsSource="{Binding ConsoleFiltersView}">
                    <ItemsControl.GroupStyle>
                      <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                          <DataTemplate>
                            <TextBlock Text="{Binding Name}" Style="{StaticResource CategoryHeader}"/>
                          </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                        <GroupStyle.Panel>
                          <ItemsPanelTemplate>
                            <WrapPanel/>
                          </ItemsPanelTemplate>
                        </GroupStyle.Panel>
                      </GroupStyle>
                    </ItemsControl.GroupStyle>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <CheckBox Content="{Binding DisplayName}"
                                  IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                  Margin="0,0,12,4"/>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Expander>
            </Border>

            <!-- Accordion Section: Sicherheitsmodus -->
            <Border Style="{StaticResource SectionCard}" Margin="{DynamicResource SpaceBottomSM}">
              <Expander Header="Sicherheitsmodus" IsExpanded="False">
                <StackPanel Margin="0,8,0,0">
                  <CheckBox Content="Sicherheitsmodus aktiv (strikt + Rückfragen)" Margin="{DynamicResource SpaceBottomSM}"
                            IsChecked="{Binding SafetyStrict}"
                            ToolTip="Kombiniert strikte Sicherheitsregeln und zusätzliche Move-Bestätigungen."/>
                  <Grid Margin="0,2,0,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="140"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Sicherheitsbereich:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding ProtectedPaths, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Semikolon-getrennte Pfade für geschützte Bereiche"
                             AutomationProperties.Name="Geschützte Pfade"/>
                  </Grid>
                  <CheckBox Content="JP-Keep nur für ausgewählte Konsolen" Margin="0,4,0,0"
                            IsChecked="{Binding JpOnlySelected}"
                            ToolTip="JP-Versionen nur für die unten definierten Konsolen bevorzugen."/>
                  <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="140"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="JP-Keep-Konsolen:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding JpKeepConsoles, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Kommagetrennt: PS1,PS2"
                             AutomationProperties.Name="JP-Keep-Konsolen"/>
                  </Grid>
                </StackPanel>
              </Expander>
            </Border>

            <!-- Accordion Section: Externe Tools -->
            <Border Style="{StaticResource SectionCard}" Margin="{DynamicResource SpaceBottomSM}">
              <Expander Header="Externe Tools" IsExpanded="False">
                <StackPanel Margin="0,8,0,0">
                  <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="100"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="38"/>
                      <ColumnDefinition Width="70"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="5"/><RowDefinition Height="Auto"/>
                      <RowDefinition Height="5"/><RowDefinition Height="Auto"/>
                      <RowDefinition Height="5"/><RowDefinition Height="Auto"/>
                      <RowDefinition Height="5"/><RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Label Grid.Row="0" Grid.Column="0" Content="chdman:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ToolChdman, UpdateSourceTrigger=PropertyChanged}" Margin="{DynamicResource SpaceRightXS}"
                            AutomationProperties.Name="chdman-Pfad"/>
                    <Button x:Name="btnBrowseChdman" Grid.Row="0" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                            AutomationProperties.Name="chdman durchsuchen"/>
                    <TextBlock x:Name="lblChdmanStatus" Grid.Row="0" Grid.Column="3" Text="–"
                               Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11" Margin="{DynamicResource SpaceLeftSM}"/>

                    <Label Grid.Row="2" Grid.Column="0" Content="dolphintool:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ToolDolphin, UpdateSourceTrigger=PropertyChanged}" Margin="{DynamicResource SpaceRightXS}"
                            AutomationProperties.Name="dolphintool-Pfad"/>
                    <Button x:Name="btnBrowseDolphin" Grid.Row="2" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                            AutomationProperties.Name="dolphintool durchsuchen"/>
                    <TextBlock x:Name="lblDolphinStatus" Grid.Row="2" Grid.Column="3" Text="–"
                               Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11" Margin="{DynamicResource SpaceLeftSM}"/>

                    <Label Grid.Row="4" Grid.Column="0" Content="7-Zip (7z):" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Tool7z, UpdateSourceTrigger=PropertyChanged}" Margin="{DynamicResource SpaceRightXS}"
                            AutomationProperties.Name="7-Zip-Pfad"/>
                    <Button x:Name="btnBrowse7z" Grid.Row="4" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                            AutomationProperties.Name="7-Zip durchsuchen"/>
                    <TextBlock x:Name="lbl7zStatus" Grid.Row="4" Grid.Column="3" Text="–"
                               Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11" Margin="{DynamicResource SpaceLeftSM}"/>

                    <Label Grid.Row="6" Grid.Column="0" Content="psxtract:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding ToolPsxtract, UpdateSourceTrigger=PropertyChanged}" Margin="{DynamicResource SpaceRightXS}"
                            AutomationProperties.Name="psxtract-Pfad"/>
                    <Button x:Name="btnBrowsePsxtract" Grid.Row="6" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                            AutomationProperties.Name="psxtract durchsuchen"/>
                    <TextBlock x:Name="lblPsxtractStatus" Grid.Row="6" Grid.Column="3" Text="–"
                               Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11" Margin="{DynamicResource SpaceLeftSM}"/>

                    <Label Grid.Row="8" Grid.Column="0" Content="ciso:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding ToolCiso, UpdateSourceTrigger=PropertyChanged}" Margin="{DynamicResource SpaceRightXS}"
                            AutomationProperties.Name="ciso-Pfad"/>
                    <Button x:Name="btnBrowseCiso" Grid.Row="8" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                            AutomationProperties.Name="ciso durchsuchen"/>
                    <TextBlock x:Name="lblCisoStatus" Grid.Row="8" Grid.Column="3" Text="–"
                               Foreground="{DynamicResource BrushTextMuted}" VerticalAlignment="Center" FontSize="11" Margin="{DynamicResource SpaceLeftSM}"/>
                  </Grid>
                  <Button x:Name="btnAutoFindTools" Content="Tools auto-entdecken"
                          ToolTip="Sucht bekannte Konvertierungstools automatisch im System"
                          Width="200" HorizontalAlignment="Left" Margin="{DynamicResource SpaceTopLG}"
                          AutomationProperties.Name="Externe Tools automatisch suchen"/>
                </StackPanel>
              </Expander>
            </Border>

            <!-- Accordion Section: DAT & Hashes -->
            <Border Style="{StaticResource SectionCard}" Margin="{DynamicResource SpaceBottomSM}">
              <Expander Header="DAT &amp; Hashes" IsExpanded="False">
                <StackPanel Margin="0,8,0,0">
                  <CheckBox Content="DAT-Verifikation aktivieren" Margin="0,0,0,12"
                            IsChecked="{Binding UseDat}"
                            ToolTip="Vergleicht Dateien mit DAT-Datenbankeinträgen (Hashes)."/>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="120"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="38"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="6"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Label Grid.Row="0" Grid.Column="0" Content="DAT-Root:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding DatRoot, UpdateSourceTrigger=PropertyChanged}" Margin="{DynamicResource SpaceRightXS}"
                            AutomationProperties.Name="DAT-Root-Verzeichnis"/>
                    <Button x:Name="btnBrowseDat" Grid.Row="0" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                            AutomationProperties.Name="DAT-Verzeichnis durchsuchen"/>
                    <Label Grid.Row="2" Grid.Column="0" Content="Hash-Typ:" VerticalAlignment="Center"/>
                    <ComboBox x:Name="cmbDatHash" Grid.Row="2" Grid.Column="1"
                              SelectedValue="{Binding DatHashType, Mode=TwoWay}"
                              SelectedValuePath="Content"
                              AutomationProperties.Name="Hash-Typ">
                      <ComboBoxItem Content="SHA1"/>
                      <ComboBoxItem Content="MD5"/>
                      <ComboBoxItem Content="CRC32"/>
                    </ComboBox>
                  </Grid>
                  <WrapPanel Margin="0,12,0,0">
                    <CheckBox Content="DAT-Fallback aktivieren" Margin="0,0,24,0"
                              IsChecked="{Binding DatFallback}"
                              ToolTip="Wenn kein exakter Treffer gefunden wird, alternative DAT-Zuordnung versuchen."/>
                    <CheckBox Content="Basis-CRC bei Scan/Konvertierung" Margin="0,0,24,0"
                              IsChecked="{Binding CrcVerifyScan}"
                              ToolTip="Basis-CRC-Prüfung auf Datei-Ebene (unabhängig von DAT)."/>
                  </WrapPanel>
                  <TextBlock Text="ℹ DAT + CRC erhöhen Genauigkeit, können den Lauf aber deutlich verlangsamen."
                             Style="{StaticResource CaptionText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>
              </Expander>
            </Border>

            <!-- Accordion Section: DAT-Mapping -->
            <Border Style="{StaticResource SectionCard}" Margin="{DynamicResource SpaceBottomSM}">
              <Expander Header="DAT-Mapping" IsExpanded="False">
                <StackPanel Margin="0,8,0,0">
                  <TextBlock Text="Ordnet Konsolen manuell ihren DAT-Dateien zu. Ohne Zuordnung wird Auto-Erkennung verwendet."
                             Style="{StaticResource CaptionText}" Margin="{DynamicResource SpaceBottomSM}" TextWrapping="Wrap"/>
                  <DataGrid MinHeight="200" MaxHeight="400"
                            ItemsSource="{Binding DatMappings}"
                            AutoGenerateColumns="False"
                            CanUserAddRows="True" CanUserDeleteRows="True"
                            SelectionMode="Single"
                            VirtualizingPanel.IsVirtualizing="True"
                            VirtualizingPanel.VirtualizationMode="Recycling"
                            ScrollViewer.CanContentScroll="True"
                            AutomationProperties.Name="DAT-Konsolen-Zuordnung">
                    <DataGrid.Resources>
                      <x:Array x:Key="DatConsoleItems" Type="{x:Type sys:String}">
                        <sys:String>PS1</sys:String>
                        <sys:String>PS2</sys:String>
                        <sys:String>PSP</sys:String>
                        <sys:String>DC</sys:String>
                        <sys:String>SAT</sys:String>
                        <sys:String>GC</sys:String>
                        <sys:String>WII</sys:String>
                      </x:Array>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                      <DataGridComboBoxColumn Header="Konsole"
                                              SelectedItemBinding="{Binding Console}"
                                              ItemsSource="{StaticResource DatConsoleItems}"
                                              Width="130"/>
                      <DataGridTextColumn Header="DAT-Datei" Binding="{Binding DatFile}" Width="*"/>
                    </DataGrid.Columns>
                  </DataGrid>
                </StackPanel>
              </Expander>
            </Border>

            <!-- Accordion Section: Profile -->
            <Border Style="{StaticResource SectionCard}" Margin="{DynamicResource SpaceBottomSM}">
              <Expander Header="Profile" IsExpanded="False">
                <StackPanel Margin="0,8,0,0">
                  <Grid Margin="{DynamicResource SpaceBottomSM}">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="130"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Profilname:" VerticalAlignment="Center"/>
                    <ComboBox x:Name="cmbConfigProfile" Grid.Column="1" IsEditable="True"
                              AutomationProperties.Name="Profilname"/>
                  </Grid>
                  <WrapPanel Margin="0,4,0,0">
                    <Button x:Name="btnProfileSave"   Content="Speichern"   Width="110" Margin="0,0,4,4" ToolTip="Aktuelle Einstellungen speichern" AutomationProperties.Name="Profil speichern"/>
                    <Button x:Name="btnProfileLoad"   Content="Laden"       Width="110" Margin="0,0,4,4" ToolTip="Gespeichertes Profil laden" AutomationProperties.Name="Profil laden"/>
                    <Button x:Name="btnProfileDelete" Content="Löschen"     Width="110" Style="{StaticResource DangerButton}" Margin="0,0,4,4" ToolTip="Profil löschen" AutomationProperties.Name="Profil löschen"/>
                    <Button x:Name="btnProfileImport" Content="Importieren" MinWidth="110" Padding="8,2" Margin="0,0,4,4" ToolTip="Profil importieren" AutomationProperties.Name="Profil importieren"/>
                    <Button x:Name="btnConfigDiff"    Content="Config-Diff" Width="110" Margin="0,0,4,4" ToolTip="Unterschiede anzeigen" AutomationProperties.Name="Config-Diff anzeigen"/>
                  </WrapPanel>
                  <TextBlock Text="Profile speichern alle Einstellungen und können zwischen verschiedenen Sammlungen gewechselt werden."
                             Style="{StaticResource CaptionText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>
              </Expander>
            </Border>

            <!-- Accordion Section: Allgemein -->
            <Border Style="{StaticResource SectionCard}" Margin="{DynamicResource SpaceBottomSM}">
              <Expander Header="Allgemein" IsExpanded="False">
                <StackPanel Margin="0,8,0,0">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="130"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="38"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="6"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Label Grid.Row="0" Grid.Column="0" Content="Papierkorb:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding TrashRoot, UpdateSourceTrigger=PropertyChanged}" Margin="{DynamicResource SpaceRightXS}"
                             ToolTip="Verzeichnis in das Duplikate verschoben werden (_TRASH)"
                             AutomationProperties.Name="Papierkorb-Verzeichnis"/>
                    <Button x:Name="btnBrowseTrash" Grid.Row="0" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                            AutomationProperties.Name="Papierkorb-Ordner durchsuchen"/>
                    <Label Grid.Row="2" Grid.Column="0" Content="Log-Level:" VerticalAlignment="Center"/>
                    <ComboBox x:Name="cmbLogLevel" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                              SelectedValue="{Binding LogLevel, Mode=TwoWay}"
                              SelectedValuePath="Content"
                              AutomationProperties.Name="Log-Level">
                      <ComboBoxItem Content="Debug"/>
                      <ComboBoxItem Content="Info"/>
                      <ComboBoxItem Content="Warning"/>
                      <ComboBoxItem Content="Error"/>
                    </ComboBox>
                  </Grid>
                  <WrapPanel Margin="0,12,0,0">
                    <Button Command="{Binding ThemeToggleCommand}" Content="{Binding ThemeToggleText}" Width="120" Margin="0,0,8,4"/>
                    <ComboBox x:Name="cmbLocale" Width="120" Margin="0,0,8,4"
                              SelectedValuePath="Content"
                              SelectedValue="{Binding Locale, Mode=TwoWay}"
                              AutomationProperties.Name="Sprache">
                      <ComboBoxItem Content="de"/>
                      <ComboBoxItem Content="en"/>
                      <ComboBoxItem Content="fr"/>
                    </ComboBox>
                    <Button x:Name="btnApplyLocale" Content="Sprache anwenden" MinWidth="140" Padding="8,2" Margin="0,0,8,4" AutomationProperties.Name="Sprache anwenden"/>
                  </WrapPanel>
                </StackPanel>
              </Expander>
            </Border>

            <!-- Accordion Section: Audit & System -->
            <Border Style="{StaticResource SectionCard}" Margin="{DynamicResource SpaceBottomSM}">
              <Expander Header="Audit &amp; System" IsExpanded="False">
                <StackPanel Margin="0,8,0,0">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="130"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="38"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="6"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Label Grid.Row="0" Grid.Column="0" Content="Audit-Root:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding AuditRoot, UpdateSourceTrigger=PropertyChanged}" Margin="{DynamicResource SpaceRightXS}"
                             AutomationProperties.Name="Audit-Root-Verzeichnis"/>
                    <Button x:Name="btnBrowseAudit" Grid.Row="0" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                            AutomationProperties.Name="Audit-Verzeichnis durchsuchen"/>
                    <Label Grid.Row="2" Grid.Column="0" Content="PS3 Dupes-Root:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Ps3DupesRoot, UpdateSourceTrigger=PropertyChanged}" Margin="{DynamicResource SpaceRightXS}"
                             AutomationProperties.Name="PS3 Dupes-Verzeichnis"/>
                    <Button x:Name="btnBrowsePs3" Grid.Row="2" Grid.Column="2" Content="&#xE838;" FontFamily="Segoe MDL2 Assets" Width="34"
                            AutomationProperties.Name="PS3 Dupes-Verzeichnis durchsuchen"/>
                  </Grid>

                  <TextBlock Text="GAMEKEY-VORSCHAU" Style="{StaticResource SectionHeader}" Margin="0,24,0,8"/>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="130"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="6"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Label Grid.Row="0" Grid.Column="0" Content="Titel:" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding GameKeyPreviewInput, UpdateSourceTrigger=PropertyChanged}"
                             Margin="{DynamicResource SpaceRightSM}" ToolTip="Beispieltitel für die GameKey-Normalisierung"
                             AutomationProperties.Name="GameKey-Vorschau Titel"/>
                    <Button Grid.Row="0" Grid.Column="2" Command="{Binding GameKeyPreviewCommand}" Content="Vorschau" Width="110"
                            AutomationProperties.Name="GameKey-Vorschau berechnen"/>
                    <Label Grid.Row="2" Grid.Column="0" Content="GameKey:" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                               Text="{Binding GameKeyPreviewOutput}" Foreground="{DynamicResource BrushAccentCyan}" TextTrimming="CharacterEllipsis"/>
                  </Grid>

                  <TextBlock Text="KONFIGURATION" Style="{StaticResource SectionHeader}" Margin="0,24,0,8"/>
                  <WrapPanel>
                    <Button x:Name="btnExportUnified" Content="Exportieren…" MinWidth="160" Padding="8,2" Margin="0,0,8,4" ToolTip="Exportiert Profil oder Gesamtkonfiguration" AutomationProperties.Name="Konfiguration exportieren"/>
                    <Button x:Name="btnConfigImport" Content="Konfig importieren" MinWidth="160" Padding="8,2" Margin="0,0,8,4" AutomationProperties.Name="Konfiguration importieren"/>
                  </WrapPanel>
                </StackPanel>
              </Expander>
            </Border>

          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- ═══ ERGEBNIS (RD-001: Tab 2 = ehemals Protokoll) ═══════════════ -->
      <TabItem Header="Ergebnis">
        <DockPanel Background="{DynamicResource BrushBackground}">
          <!-- Dashboard -->
          <Border DockPanel.Dock="Top" Background="{DynamicResource BrushSurfaceAlt}"
                  BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="8"
                  Padding="12,8" Margin="12" MaxHeight="300">
            <Border.Effect>
              <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.25" Color="#000000"/>
            </Border.Effect>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0">
                <TextBlock Text="ERGEBNIS-DASHBOARD" Style="{StaticResource SectionHeader}" Margin="{DynamicResource SpaceBottomSM}"/>
                <WrapPanel Margin="{DynamicResource SpaceBottomXS}">
                  <Border Style="{StaticResource MetricCard}" MinWidth="100" Margin="0,0,8,8">
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Text="Modus" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                      <TextBlock Text="{Binding DashMode}" Foreground="{DynamicResource BrushTextPrimary}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"
                                 AutomationProperties.Name="Aktueller Modus" AutomationProperties.LiveSetting="Polite"/>
                    </StackPanel>
                  </Border>
                  <Border Style="{StaticResource MetricCard}" MinWidth="90" Margin="0,0,8,8">
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Text="Winner" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                      <TextBlock Text="{Binding DashWinners}" Foreground="{DynamicResource BrushSuccess}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"
                                 AutomationProperties.Name="Anzahl Winner" AutomationProperties.LiveSetting="Polite"/>
                    </StackPanel>
                  </Border>
                  <Border Style="{StaticResource MetricCard}" MinWidth="90" Margin="0,0,8,8">
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Text="Duplikate" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                      <TextBlock Text="{Binding DashDupes}" Foreground="{DynamicResource BrushWarning}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"
                                 AutomationProperties.Name="Anzahl Duplikate" AutomationProperties.LiveSetting="Polite"/>
                    </StackPanel>
                  </Border>
                  <Border Style="{StaticResource MetricCard}" MinWidth="90" Margin="0,0,8,8">
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Text="Junk" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                      <TextBlock Text="{Binding DashJunk}" Foreground="{DynamicResource BrushDanger}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"
                                 AutomationProperties.Name="Anzahl Junk" AutomationProperties.LiveSetting="Polite"/>
                    </StackPanel>
                  </Border>
                  <Border Style="{StaticResource MetricCard}" MinWidth="90" Margin="0,0,8,8">
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Text="Laufzeit" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                      <TextBlock Text="{Binding DashDuration}" Foreground="{DynamicResource BrushTextPrimary}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"
                                 AutomationProperties.Name="Laufzeit" AutomationProperties.LiveSetting="Polite"/>
                    </StackPanel>
                  </Border>
                  <Border Style="{StaticResource MetricCard}" MinWidth="90" Margin="0,0,8,8">
                    <StackPanel HorizontalAlignment="Center">
                      <TextBlock Text="Health" Style="{StaticResource CaptionText}" HorizontalAlignment="Center"/>
                      <TextBlock Text="{Binding HealthScore}" Foreground="{DynamicResource BrushAccentCyan}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"
                                 AutomationProperties.Name="Health-Score" AutomationProperties.LiveSetting="Polite"/>
                    </StackPanel>
                  </Border>
                </WrapPanel>
                <!-- Performance Details -->
                <Expander Header="Performance-Details" IsExpanded="False" Margin="0,0,0,2">
                  <WrapPanel Margin="0,4,0,0">
                    <TextBlock Text="{Binding ProgressText}" Foreground="{DynamicResource BrushAccentCyan}" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding PerfPhase}" Foreground="{DynamicResource BrushTextMuted}" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding PerfFile}" Foreground="{DynamicResource BrushTextMuted}" TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                  </WrapPanel>
                </Expander>
              </StackPanel>
              <Button Grid.Column="1" Command="{Binding OpenReportCommand}" Width="150" Height="28"
                      VerticalAlignment="Center" ToolTip="HTML-Bericht öffnen (Ctrl+R)"
                      AutomationProperties.Name="HTML-Bericht öffnen">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A7;" Margin="{DynamicResource SpaceRightSM}"/>
                  <TextBlock Text="Bericht öffnen"/>
                </StackPanel>
              </Button>
            </Grid>
          </Border>

          <!-- Log Footer -->
          <Border DockPanel.Dock="Bottom" Background="{DynamicResource BrushSurfaceAlt}"
                  BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,1,0,0" Padding="12,8">
            <StackPanel Orientation="Horizontal">
              <Button Command="{Binding ClearLogCommand}" Content="Log leeren" Width="118" Margin="{DynamicResource SpaceRightSM}"/>
              <Button x:Name="btnExportLog" Content="Log exportieren" MinWidth="130" Padding="8,2" AutomationProperties.Name="Log exportieren"/>
            </StackPanel>
          </Border>

          <!-- Log and Report Preview -->
          <Grid Margin="0" Background="{DynamicResource BrushBackground}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="2*" MinWidth="200"/>
              <ColumnDefinition Width="8"/>
              <ColumnDefinition Width="*" MinWidth="120"/>
            </Grid.ColumnDefinitions>
            <ListBox x:Name="listLog" Grid.Column="0"
                     ItemsSource="{Binding LogEntries}"
                     Background="{DynamicResource BrushBackground}" Foreground="{DynamicResource BrushAccentCyan}"
                     FontFamily="Consolas" FontSize="11"
                     BorderThickness="0" Margin="12,12,0,12"
                     ItemTemplate="{StaticResource LogEntryTemplate}"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.CanContentScroll="True"
                     AutomationProperties.Name="Protokoll-Einträge"/>
            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeWE"
                          AutomationProperties.Name="Log und Vorschau Größe anpassen"/>
            <Border Grid.Column="2" Style="{StaticResource SectionCard}" Margin="0,12,12,12">
              <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="{DynamicResource SpaceBottomSM}">
                  <TextBlock Text="REPORT-VORSCHAU" Style="{StaticResource SectionHeader}" Margin="{DynamicResource SpaceRightSM}"/>
                  <Button x:Name="btnRefreshReportPreview" Width="120" Height="28" Content="Aktualisieren"
                          AutomationProperties.Name="Berichtsvorschau aktualisieren"/>
                </StackPanel>
                <Border DockPanel.Dock="Top" Background="{DynamicResource BrushSurfaceAlt}" BorderBrush="{DynamicResource BrushBorder}"
                        BorderThickness="1" CornerRadius="6" Padding="8" Margin="{DynamicResource SpaceBottomSM}">
                  <StackPanel>
                    <TextBlock Text="FEHLER-SUMMARY" Style="{StaticResource SectionHeader}" Margin="{DynamicResource SpaceBottomXS}"/>
                    <ListBox x:Name="listErrorSummary" MinHeight="60"
                             ItemsSource="{Binding ErrorSummaryItems}"
                             Background="{DynamicResource BrushBackground}" Foreground="{DynamicResource BrushWarning}"
                             BorderThickness="0" FontFamily="Consolas" FontSize="11"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             ScrollViewer.CanContentScroll="True"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             AutomationProperties.Name="Fehler-Summary"/>
                  </StackPanel>
                </Border>
                <wv2:WebView2 x:Name="webReportPreview" MinHeight="80"
                             AutomationProperties.Name="HTML-Berichtsvorschau"
                             AutomationProperties.HelpText="Zeigt den generierten HTML-Report als Vorschau an."/>
              </DockPanel>
            </Border>
          </Grid>
        </DockPanel>
      </TabItem>

    </TabControl>
  </DockPanel>
</Window>
