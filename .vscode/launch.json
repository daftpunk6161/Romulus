{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug: WPF GUI",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/RomCleanup.UI.Wpf/bin/Debug/net10.0-windows/RomCleanup.Wpf.exe",
            "args": [],
            "cwd": "${workspaceFolder}",
            "console": "internalConsole",
            "stopAtEntry": false
        },
        {
            "name": "Debug: CLI (DryRun)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/RomCleanup.CLI/bin/Debug/net10.0/romcleanup.exe",
            "args": ["--roots", "D:\\Roms", "--mode", "DryRun"],
            "cwd": "${workspaceFolder}",
            "console": "internalConsole",
            "stopAtEntry": false
        },
        {
            "name": "Debug: REST API",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/RomCleanup.Api/bin/Debug/net10.0/RomCleanup.Api.exe",
            "args": [],
            "cwd": "${workspaceFolder}",
            "console": "internalConsole",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        },
        {
            "name": "Debug: Tests",
            "type": "node-terminal",
            "request": "launch",
            "command": "dotnet test ${workspaceFolder}/src/RomCleanup.Tests/RomCleanup.Tests.csproj --no-build",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Run: simple_sort GUI (STA)",
            "type": "node-terminal",
            "request": "launch",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -STA -File ${workspaceFolder}\\simple_sort.ps1",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Run: Current PowerShell File",
            "type": "node-terminal",
            "request": "launch",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ${file}",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Run: simple_sort GUI (pwsh)",
            "type": "node-terminal",
            "request": "launch",
            "command": "pwsh.exe -NoProfile -ExecutionPolicy Bypass -STA -File ${workspaceFolder}\\simple_sort.ps1",
            "cwd": "${workspaceFolder}"
        }
    ]
}